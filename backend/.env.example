PORT=4000
DATABASE_URL="postgresql://helm:helm@localhost:5432/helm"

# STUB: no real Firebase project exists yet. Any string works for local boot;
# every request will be rejected until this is a real (or emulated) project id.
FIREBASE_PROJECT_ID=helm-dev-stub

# Local dev only: point firebase-admin at the Firebase Auth Emulator
# (`npx firebase emulators:start --only auth`) instead of real Firebase, so
# sign up/in/out can be exercised end-to-end without a real project. Leave
# unset outside local dev.
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# LiveCode (github.com/NathanTheDev/LiveCode) - the headless notes
# collaboration service a note is published to. Run its own docker-compose
# locally (backend on :3000, ysocket on :1234); INTERNAL_API_KEY must match
# its backend/.env exactly.
NOTES_BACKEND_URL=http://localhost:3000
NOTES_INTERNAL_API_KEY=livecode-dev-stub-internal-key

# Google Calendar OAuth (console.cloud.google.com - Calendar API enabled,
# OAuth consent screen configured, Web application client). Redirect URI
# below must exactly match one registered on the client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/oauth/callback

# Encrypts stored Calendar OAuth tokens at rest (AES-256-GCM). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Frontend origin - the backend redirects the browser back here once
# Google's OAuth callback finishes.
FRONTEND_URL=http://localhost:3000
