PORT=4000
DATABASE_URL="postgresql://helm:helm@localhost:5432/helm"

# STUB: no real Firebase project exists yet. Any string works for local boot;
# every request will be rejected until this is a real (or emulated) project id.
FIREBASE_PROJECT_ID=helm-dev-stub

# Local dev only: point firebase-admin at the Firebase Auth Emulator
# (`npx firebase emulators:start --only auth`) instead of real Firebase, so
# sign up/in/out can be exercised end-to-end without a real project. Leave
# unset outside local dev.
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
