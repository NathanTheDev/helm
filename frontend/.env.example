# Base URL of the helm backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# STUB: Firebase web client config - safe to expose in a client bundle, not
# secrets. No real project exists yet; these placeholders + the emulator
# host below let sign up/in/out be exercised end-to-end without one.
NEXT_PUBLIC_FIREBASE_API_KEY=stub-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=stub-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=helm-dev-stub
NEXT_PUBLIC_FIREBASE_APP_ID=stub-app-id
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# LiveCode (github.com/NathanTheDev/LiveCode)'s ysocket - the WebSocket
# endpoint a published note's collaborative editor connects to. Run
# LiveCode's own docker-compose locally (ysocket on :1234).
NEXT_PUBLIC_NOTES_WS_URL=ws://localhost:1234
